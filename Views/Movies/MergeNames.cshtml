@model MovieMVC.Models.ViewModels.MergeNamesViewModel

@{
    ViewData["Title"] = "Merge Names";
}

<h2>Merge Names</h2>
<p>Select the correct name in the first dropdown. Names selected in dropdowns 2–6 will have their movie references merged into the correct name, then be deleted.</p>

@if (TempData["SuccessMessage"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<div asp-validation-summary="All" class="text-danger"></div>

<form method="post">
    <div class="mb-3">
        <label class="form-label fw-bold">Correct Name (target) <span class="text-danger">*</span></label>
        <select name="targetId" class="form-select" asp-items="Model.Names">
            <option value="">-- Select --</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Merge Name 2 <span class="text-danger">*</span></label>
        <select name="sourceId2" class="form-select" asp-items="Model.Names">
            <option value="">-- Select --</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Merge Name 3 (optional)</label>
        <select name="sourceId3" class="form-select" asp-items="Model.Names">
            <option value="">-- Select --</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Merge Name 4 (optional)</label>
        <select name="sourceId4" class="form-select" asp-items="Model.Names">
            <option value="">-- Select --</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Merge Name 5 (optional)</label>
        <select name="sourceId5" class="form-select" asp-items="Model.Names">
            <option value="">-- Select --</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Merge Name 6 (optional)</label>
        <select name="sourceId6" class="form-select" asp-items="Model.Names">
            <option value="">-- Select --</option>
        </select>
    </div>

    <button type="submit" class="btn btn-danger">Merge</button>
    <a class="btn btn-outline-secondary" href="/Home?sort=@Context.Request.Query["sort"]&desc=@Context.Request.Query["desc"]&search=@Context.Request.Query["search"]">Back to List</a>
</form>
