@model MovieMVC.Models.ViewModels.NamesViewModel

@{
    ViewData["Title"] = "Names Maintenance";
}

<div class="movie-page home-header">
    <h2>Names Maintenance</h2>

    <partial name="_TempMessages" />

    <div class="mb-4">
        <h4>Add New Name</h4>
        <form method="post" asp-action="AddName" class="d-inline-flex gap-2 align-items-center">
            <partial name="_SortSearchHidden" />
            <input type="text" name="name" class="form-control" placeholder="Enter name" required style="width: 300px;" />
            <button type="submit" class="btn btn-success">Add</button>
        </form>
    </div>

    <div class="mb-3">
        <input id="nameSearchBox" type="text" class="form-control" placeholder="Search names..." autocomplete="off" style="width: 300px; display: inline-block;" />
        <button type="button" class="btn btn-primary" onclick="document.getElementById('nameSearchBox').value=''; document.getElementById('nameSearchBox').dispatchEvent(new Event('input'));">Clear</button>
    </div>

    <div id="namesTableContainer" style="max-height: 70vh; overflow-y: auto;">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width: 350px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var nameEntry in Model.Names)
            {
                <tr data-id="@nameEntry.Id">
                    <td>
                        <form method="post" asp-action="EditName" class="d-inline-flex gap-2 align-items-center w-100">
                                <partial name="_SortSearchHidden" />
                            <input type="hidden" name="id" value="@nameEntry.Id" />
                            <input type="text" name="name" value="@nameEntry.Name" class="form-control" required />
                            <button type="submit" class="btn btn-sm btn-primary">Save</button>
                        </form>
                    </td>
                    <td>
                        @if (!nameEntry.CanDelete)
                        {
                            <button type="button" class="btn btn-sm btn-danger" onclick="alert('You cannot delete this Name as it is associated with at least one movie.');">Delete</button>
                        }
                        else
                        {
                            <form method="post" asp-action="DeleteName" class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete \'@nameEntry.Name.Replace("'", "\\'")\'?');">
                                <partial name="_SortSearchHidden" />
                                <input type="hidden" name="id" value="@nameEntry.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <div class="mt-3">
        <a class="btn btn-secondary" href="/Home?sort=@Model.Sort&desc=@Model.Desc&search=@Model.Search">Back to List</a>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('nameSearchBox').addEventListener('input', function () {
        var text = this.value.toLowerCase();
        var container = document.getElementById('namesTableContainer');
        var rows = container.querySelectorAll('tbody tr');
        // Remove previous highlighted row
        var prev = container.querySelector('tbody tr.search-highlight');
        if (prev) prev.classList.remove('search-highlight');
        // If search box is empty, don't highlight or scroll
        if (text.length === 0) return;

        // Finds the first row that starts with the search text and highlights it, then scrolls it into view
        for (var i = 0; i < rows.length; i++) {
            var nameInput = rows[i].querySelector('td input[name="name"]');
            if (nameInput && nameInput.value.trim().toLowerCase().startsWith(text)) {
                rows[i].classList.add('search-highlight');
                //Calculates the offset to center the matched row within the scrollable #namesTableContainer div, 
                // then adjusts container.scrollTop accordingly. 
                // This avoids scrollIntoView(), which caused conflicts with Edge's focus-scroll behavior.
                var containerRect = container.getBoundingClientRect();
                var rowRect = rows[i].getBoundingClientRect();
                container.scrollTop += rowRect.top - containerRect.top - (container.clientHeight / 2) + (rows[i].clientHeight / 2);
                //stops after the first match.
                break;
            }
        }
    });

    var focusId = '@Model.FocusNameId';
    if (focusId) {
        var container = document.getElementById('namesTableContainer');
        var row = container.querySelector('tr[data-id="' + focusId + '"]');
        if (row) {
            row.classList.add('search-highlight');
            var containerRect = container.getBoundingClientRect();
            var rowRect = row.getBoundingClientRect();
            container.scrollTop += rowRect.top - containerRect.top - (container.clientHeight / 2) + (row.clientHeight / 2);
            var nameInput = row.querySelector('input[name="name"]');
            // calls focus({ preventScroll: true }) on that row's name input so the user can immediately re-edit, 
            // without the browser fighting the scroll position.
            //  the page scroll stays put and only the container's internal scroll moves.
            if (nameInput) nameInput.focus({ preventScroll: true });
        }
    }
</script>
}
