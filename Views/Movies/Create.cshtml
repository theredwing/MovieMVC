@model MovieMVC.Models.ViewModels.MovieFormViewModel

@{
    ViewData["Title"] = "Add";
}

<div class="movie-page home-header">
    <h2>Add Movie</h2>

    @if (TempData["ErrorMessage"] is string errorMsg)
    {
        <div class="alert alert-danger">@errorMsg</div>
    }

<form method="post">
    <input type="hidden" name="sort" value="@Context.Request.Query["sort"]" />
    <input type="hidden" name="desc" value="@Context.Request.Query["desc"]" />
    <input type="hidden" name="search" value="@Context.Request.Query["search"]" />

    <div class="mb-3">
        <label asp-for="Movie.Title" class="form-label"></label>
        <input asp-for="Movie.Title" class="form-control" />
        <span asp-validation-for="Movie.Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Movie.Description" class="form-label"></label>
        <textarea asp-for="Movie.Description" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Directors</label>
        <select name="selectedDirectors" multiple="multiple" class="form-select" asp-items="Model.Directors"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Producers</label>
        <select name="selectedProducers" multiple="multiple" class="form-select" asp-items="Model.Producers"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Writers</label>
        <select name="selectedWriters" multiple="multiple" class="form-select" asp-items="Model.Writers"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Actors</label>
        <select name="selectedActors" multiple="multiple" class="form-select" asp-items="Model.Actors"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Categories</label>
        <select name="selectedCategories" multiple="multiple" class="form-select" asp-items="Model.Categories"></select>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" href="/Home?sort=@Context.Request.Query["sort"]&desc=@Context.Request.Query["desc"]&search=@Context.Request.Query["search"]">Cancel</a>
</form>
